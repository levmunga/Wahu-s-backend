# Copy this file to .env and fill in real values before running.
# Never commit your actual .env file (it's already in .gitignore).

# A long random string used to sign admin login sessions.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Port the server listens on. Render sets this automatically in production,
# so you usually don't need to set it yourself when deploying.
PORT=3000

# Set to "production" when deployed (enables secure cookies over HTTPS).
NODE_ENV=development

# The exact URL of your storefront, e.g. https://wahuscloset.co.ke
# Used to restrict which websites are allowed to call this API.
ALLOWED_ORIGIN=http://localhost:5500
